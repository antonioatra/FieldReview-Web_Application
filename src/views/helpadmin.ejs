<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Field Review - Help Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/help-admin.css">
</head>
<body class="bg-gray-100">
    <!-- Header -->
    <%- include('../partials/header') %>

    <!-- Main Content -->
    <main class="min-h-screen bg-gray-100 py-8">
        <div class="max-w-6xl mx-auto px-4">
            <!-- Title Section -->
            <div class="text-center mb-8">
                <h1 class="text-2xl font-semibold text-gray-800 mb-2">Perguntas frequentes</h1>
                <p class="text-gray-600 mb-6">Help disponível na plataforma</p>
                
                <!-- Add Help Button -->
                <button id="addHelpBtn" class="bg-green-500 hover:bg-green-600 text-white px-6 py-2 rounded-md font-medium transition-colors">
                    ● Adicionar Help
                </button>
            </div>

            <!-- Help Cards Container -->
            <div id="helpCardsContainer" class="space-y-4">
                <!-- Help cards will be dynamically loaded here -->
            </div>
        </div>
    </main>

    <!-- Modal Overlay -->
    <div id="modalOverlay" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50">
        <!-- Modal -->
        <div class="fixed inset-0 flex items-center justify-center p-4">
            <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6">
                <!-- Modal Header -->
                <div class="flex justify-between items-center mb-4">
                    <h2 id="modalTitle" class="text-xl font-semibold text-blue-900">Adicione um novo card no help</h2>
                    <button id="closeModalBtn" class="text-gray-400 hover:text-gray-600">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>

                <!-- Modal Form -->
                <form id="helpForm">
                    <div class="space-y-4">
                        <!-- Title Input -->
                        <div>
                            <label for="helpTitle" class="block text-sm font-medium text-gray-700 mb-1">Alterar o título</label>
                            <input 
                                type="text" 
                                id="helpTitle" 
                                name="title"
                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                placeholder="Digite o título do help"
                                required
                            >
                        </div>

                        <!-- Content Input -->
                        <div>
                            <label for="helpContent" class="block text-sm font-medium text-gray-700 mb-1">Alterar conteúdo</label>
                            <textarea 
                                id="helpContent" 
                                name="content"
                                rows="4"
                                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                placeholder="Digite o conteúdo do help"
                                required
                            ></textarea>
                        </div>
                    </div>

                    <!-- Modal Actions -->
                    <div class="flex justify-end space-x-3 mt-6">
                        <button 
                            type="button" 
                            id="cancelBtn"
                            class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-md font-medium transition-colors"
                        >
                            Cancelar
                        </button>
                        <button 
                            type="submit"
                            class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-md font-medium transition-colors"
                        >
                            Concluir
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Loading Screen -->
    <div id="loadingScreen" class="fixed inset-0 bg-white flex items-center justify-center z-40">
        <div class="text-center">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-900 mx-auto mb-4"></div>
            <p class="text-gray-600">Carregando...</p>
        </div>
    </div>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- JavaScript -->
    <script src="/js/help-admin.js"></script>
</body>
</html>