<% if (!isAdministrator) { %>
  <a href="/trail/<%= trail.id %>/<%= firstId %>">
    <% } else { %>
      <a>
        <% } %>

          <div class="bg-[#F6F6F6] text-white rounded-lg m-sm shadow-md hover:shadow-lg transition relative <%= typeof isCompleted !== 'undefined' && isCompleted ? 'border-l-4 border-green-500' : '' %>">
            <% if (typeof isCompleted !== 'undefined' && isCompleted) { %>
              <div class="flex items-center mb-2 pt-4 px-6">
                <div class="w-3 h-3 bg-green-500 rounded-full mr-3"></div>
                <span class="text-green-600 font-semibold text-sm">CONCLUÍDA</span>
              </div>
            <% } %>
            <h4 class="text-lg font-bold text-black <%= typeof isCompleted !== 'undefined' && isCompleted ? 'px-6 pb-4' : 'p-6' %>">
              <%= trail.titulo %>
            </h4>
            <% if (isAdministrator) { %>
              <div class="flex p-2 flex-col absolute right-2 top-2 gap-2">
                <button class="text-green-600 hover:text-green-800 mr-2" onclick="editTrail('<%= trail.id %>')">
                  <img src="/pencil.svg" class="w-5" alt="Editar" />
                </button>
                <button class="text-red-600 hover:text-red-800" onclick="deleteTrail('<%= trail.id %>')">
                  <img src="/trash.svg" class="w-5" alt="Apagar" />
                </button>
              </div>
              <% } %>

                <div class="flex justify-between items-center border-t border-black mt-4 py-4">
                  <div>
                    <p class="mt-2 text-black font-semibold px-4">
                      <%= moduleCount || 0 %> Módulos
                    </p>
                    <p class="mt-2 text-black px-4">
                      Pessoas que completaram: <%= trail.completedCount || 15 %>
                    </p>
                  </div>

                  <div class="mr-4">
                    <!-- Círculo de progresso simples -->
                    <div class="relative w-20 h-20 rounded-full border-4 <%= typeof isCompleted !== 'undefined' && isCompleted ? 'border-green-500' : 'border-gray-300' %> flex items-center justify-center">
                      <!-- Barra de progresso circular usando conic-gradient inline -->
                      <div 
                        class="absolute inset-0 rounded-full"
                        style="background: conic-gradient(#22c55e 0% <%= trail.progress || 0 %>%, transparent <%= trail.progress || 0 %>% 100%);"
                      ></div>
                      <!-- Círculo interno branco -->
                      <div class="relative w-14 h-14 bg-white rounded-full flex items-center justify-center z-10">
                        <span class="<%= typeof isCompleted !== 'undefined' && isCompleted ? 'text-green-600' : 'text-black' %> text-sm font-semibold">
                          <%= Math.round(trail.progress || 0) %>%
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
          </div>
      </a>

      <script>
        function editTrail(trailId) {
          window.location.href = `/trail/edit/${trailId}`;
        }

        async function deleteTrail(trailId) {
          if (confirm('Tem certeza que deseja deletar esta trilha?')) {
            try {
              const response = await fetch(`/api/trail/${trailId}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
              });
              const data = await response.json();
              if (response.ok) {
                alert(data.message);
                location.reload(); // Reload to reflect the deletion
              } else {
                alert(data.error);
              }
            } catch (error) {
              alert('Erro ao deletar trilha');
              console.error(error);
            }
          }
        }
      </script>
  </a>