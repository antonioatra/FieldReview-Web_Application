  <div class="flex">
    <form action="/search" method="GET" class="relative">
      <input 
        type="text" 
        name="q" 
        placeholder="Pesquisar..." 
        class="p-2 pr-10 rounded-md bg-white text-black sm:w-96 w-55" 
      />
      <img src="/assets/lupaHelp.svg" class="absolute right-3 top-3/4 transform -translate-y-1/2 w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
