    <a href="/profile" class="hover:bg-gray-200 p-2 rounded-lg transition-colors">
      <img src = "/assets/perfil.svg">
    </a>
  </div>

  <div class="md:hidden relative">
    <button 
      id="mobileMenuButton" 
      class="p-2 hover:bg-gray-200 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500"
      aria-label="Menu"
    >
      <div class="hamburger-icon">
        <span class="hamburger-line block w-6 h-0.5 bg-gray-600 transition-all duration-300 ease-in-out"></span>
