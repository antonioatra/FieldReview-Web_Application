        <span class="hamburger-line block w-6 h-0.5 bg-gray-600 mt-1.5 transition-all duration-300 ease-in-out"></span>
      </div>
    </button>
    
    <div 
      id="mobileMenuDropdown" 
      class="absolute right-0 top-full mt-2 w-56 bg-white rounded-xl shadow-xl border border-gray-200 py-2 z-50 transform opacity-0 scale-95 transition-all duration-200 ease-out invisible"
    >
      <div class="absolute -top-2 right-4 w-4 h-4 bg-white border-l border-t border-gray-200 transform rotate-45"></div>
      <a href="/help" class="flex items-center px-4 py-3 hover:bg-gray-50 transition-colors group">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center mr-3 group-hover:bg-blue-200 transition-colors">
          <img src="/assets/helpHome.svg">
        </div>
        <div class="flex-1">
          <h4 class="font-semibold text-gray-800 group-hover:text-blue-600 transition-colors">Help</h4>
        </div>
        <svg class="w-4 h-4 text-gray-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
      
