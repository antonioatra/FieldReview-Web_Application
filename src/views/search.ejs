<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FieldReview - Pesquisa</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  </head>
  <body>
    <%- include('./partials/header.ejs') %>

    <main class="p-6 min-h-screen">
      <section class="mb-6">
        <h2 class="text-3xl font-bold text-blue-900">Pesquisa</h2>
      </section>

      <div class="flex flex-col gap-10">
        <div>
          <p class="text-blue-900 font-semibold mb-2">Resultados do Help</p>

          <% if (results && results.length > 0) { %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% results.forEach(result => { %>
            <div class="bg-black/2 p-6 rounded-lg border-1 border-black/10 max-w-xs">
              <h3 class="text-xl font-bold text-blue-900 mb-2"><%= result.title %></h3>
              <p><%= result.description %></p>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="text-gray-600">Nenhum resultado encontrado.</p>
          <% } %>
        </div>

        <div>
          <p class="text-blue-900 font-semibold mb-2">Resultados dos Módulos</p>
          <% if (results && results.length > 0) { %>
          <div class="flex flex-col">
            <% results.forEach(result => { %>
            <div class="bg-black/2 p-6 rounded-lg border-1 border-black/10 w-full space-y-6">
              <h3 class="text-xl font-bold text-blue-900 mb-2"><%= result.title %></h3>
              <p class="max-w-6xl"><%= result.description %></p>
              <a class="text-blue-900">Ver mais</a>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="text-gray-600">Nenhum resultado encontrado.</p>
          <% } %>
        </div>
      </div>
    </main>

    <%- include('./partials/footer.ejs') %>
  </body>
</html>
