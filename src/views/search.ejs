<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FieldReview - Pesquisa</title>
    <!-- Tailwind CSS CDN -->
    <link
      href="https://cdn.tailwindcss.com"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white">
    <%- include('./partials/header.ejs') %>

    <main class="p-6 min-h-screen md:mx-20">
      <section class="mb-6">
        <h2 class="text-3xl text-black">
          Resultados da sua pesquisa: <%= searchTerm || 'Nenhum termo' %>
        </h2>
      </section>

      <% if (error) { %>
      <p class="text-red-600"><% error %></p>
      <% } else { %>
      <div class="flex flex-col gap-10">
        <!-- Help Results -->
        <div>
          <p class="text-blue-900 font-semibold mb-2">Resultados do Help</p>
          <% if (helpResults && helpResults.length > 0) { %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% helpResults.forEach(result => { %>
            <div class="bg-black/2 p-6 rounded-lg shadow-md border border-gray-200 max-w-xs">
              <h3 class="text-xl font-bold text-blue-900 mb-2"><%= result.titulo %></h3>
              <p class="text-gray-700"><%= result.conteudo %></p>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="text-gray-600">Nenhum resultado encontrado para Help.</p>
          <% } %>
        </div>

        <!-- Trail Results -->
        <div>
          <p class="text-blue-900 font-semibold mb-2">Resultados dos Módulos</p>
          <% if (trailResults && trailResults.length > 0) { %>
          <div class="flex flex-col gap-4">
            <% trailResults.forEach(result => { %>
            <div
              class="bg-black/2 p-6 rounded-lg shadow-md border border-gray-200 w-full space-y-6"
            >
              <h3 class="text-xl font-bold text-blue-900 mb-2">
                <%= result.titulo.replace(/<[^>]*>|[#*_`~]/g, '') %>
              </h3>
              <% const searchTermLower = searchTerm.toLowerCase(); const rawContent =
              result.conteudo .replace(/<[^>]*>/g, '') .replace(/[#*_`~\[\]()]/g, '')
              .replace(/\!?\[.*?\]\(.*?\)/g, ''); const words = rawContent.split(/\s+/); const
              foundIndex = words.findIndex(word => word.toLowerCase().includes(searchTermLower)); if
              (foundIndex >= 0) { const start = Math.max(0, foundIndex - 100); const end =
              Math.min(words.length, foundIndex + 100); const excerpt = words.slice(start,
              end).join(' '); %>
              <p class="max-w-6xl text-gray-700">
                <% if (start > 0) { %>...<% } %> <%= excerpt %> <% if (end < words.length) { %>...<%
                } %>
              </p>
              <% } else { %>
              <p class="max-w-6xl text-gray-700"><%= rawContent %></p>
              <% } %>
              <a href="#" class="text-blue-900 hover:underline font-bold">Ver mais</a>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="text-gray-600">Nenhum resultado encontrado para Módulos.</p>
          <% } %>
        </div>
      </div>
      <% } %>
    </main>

    <%- include('./partials/footer.ejs') %>
  </body>
</html>
