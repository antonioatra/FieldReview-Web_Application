<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FieldReview - Pesquisa</title>
    <!-- Tailwind CSS CDN -->
    <link
      href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white">
    <%- include('./partials/header.ejs') %>

    <main class="p-6 min-h-screen md:mx-20">
      <section class="mb-6">
        <h2 class="text-3xl text-black">
          Resultados da sua pesquisa: <%= searchTerm || 'Nenhum termo' %>
        </h2>
      </section>

      <% if (error) { %>
      <p class="text-red-600"><% error %></p>
      <% } else { %>
      <div class="flex flex-col gap-10">
        <!-- Help Results -->
        <div>
          <p class="text-blue-900 font-semibold mb-2">Resultados do Help</p>
          <% if (helpResults && helpResults.length > 0) { %>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <% helpResults.forEach(result => { %>
            <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200 max-w-xs">
              <h3 class="text-xl font-bold text-blue-900 mb-2"><%= result.title %></h3>
              <p class="text-gray-700"><%= result.description %></p>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="text-gray-600">Nenhum resultado encontrado para Help.</p>
          <% } %>
        </div>

        <!-- Trail Results -->
        <div>
          <p class="text-blue-900 font-semibold mb-2">Resultados dos Módulos</p>
          <% if (trailResults && trailResults.length > 0) { %>
          <div class="flex flex-col gap-4">
            <% trailResults.forEach(result => { %>
            <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200 w-full space-y-6">
              <h3 class="text-xl font-bold text-blue-900 mb-2"><%= result.title %></h3>
              <p class="max-w-6xl text-gray-700"><%= result.description %></p>
              <a href="#" class="text-blue-900 hover:underline">Ver mais</a>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <p class="text-gray-600">Nenhum resultado encontrado para Módulos.</p>
          <% } %>
        </div>
      </div>
      <% } %>
    </main>

    <%- include('./partials/footer.ejs') %>
  </body>
</html>
